<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="150.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/23.0.1"
            fx:controller="org.isfce.pdb.view.plan.VuePlanController">
    <children>
        <Label layoutX="10.0" layoutY="20.0" text="Nom :" styleClass="main-label"/>
        <TextField fx:id="ztNom" layoutX="150.0" layoutY="18.0"
                   AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="10.0"/>

        <HBox alignment="CENTER_RIGHT" spacing="10.0"
              AnchorPane.bottomAnchor="10.0" AnchorPane.rightAnchor="10.0">
            <children>
                <Button text="%action.ok" onAction="#actionValider"/>
                <Button text="%action.annuler" onAction="#actionAnnuler"/>
            </children>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </padding>
        </HBox>
    </children>
</AnchorPane>