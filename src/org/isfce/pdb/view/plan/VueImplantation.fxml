<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="737.0" prefWidth="1122.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.isfce.pdb.view.plan.VueImplantationController">
   <center>
      <ScrollPane fx:id="spCanvas" fitToHeight="true" fitToWidth="true" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <content>
            <Canvas fx:id="canvas" height="657.0" width="872.0" />
         </content>
      </ScrollPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btValider" mnemonicParsing="false" onAction="#actionValider" text="%action.ok" />
            <Button fx:id="btAnnuler" mnemonicParsing="false" onAction="#actionQuitter" text="%action.quitter" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
   <left>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <ComboBox fx:id="cbPlans" maxWidth="1.7976931348623157E308" onAction="#actionChargePlan" prefWidth="150.0" />
            <ListView fx:id="lstElements" prefHeight="585.0" prefWidth="200.0" />
         </children>
      </VBox>
   </left>
</BorderPane>
