<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.isfce.pdb.view.piece.VueListePiecesController">
   <children>
      <Label layoutX="277.0" layoutY="23.0" styleClass="titre" text="%piece.liste.titre" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0" />
      <ScrollPane fitToHeight="true" fitToWidth="true" layoutX="12.0" layoutY="73.0" prefHeight="485.0" prefWidth="790.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="60.0">
         <content>
            <TableView fx:id="tblPieces" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="colNom" prefWidth="75.0" text="%piece.nom" />
                <TableColumn fx:id="colDescription" prefWidth="75.0" text="%piece.description" />
